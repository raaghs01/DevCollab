PORT=4000

# Base URL of the Next.js app, used to persist/load Yjs room state
NEXT_INTERNAL_API_URL=http://localhost:3000

# Must match REALTIME_SERVER_INTERNAL_SECRET in the Next.js app's .env
REALTIME_SERVER_INTERNAL_SECRET=dev-only-shared-secret

# Origin allowed to open Socket.io connections
CORS_ORIGIN=http://localhost:3000
